# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
# Server-side only — bypasses row-level security. Never expose to the client or commit.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx
# Legacy alias — same value as SUPABASE_SECRET_KEY. Some helpers still read this name.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx
# Anon key for Playwright evals (publishable key works here too).
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Mapbox — Account > Tokens (public token, starts with pk.)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxxxxx
# Server-only geocoding token (T059 reverse-geocoder). Distinct from the public one above.
MAPBOX_GEOCODING_TOKEN=

# Follow notification email (T018)
# Get from https://resend.com/api-keys (starts with re_)
RESEND_API_KEY=
# Sender address. Use onboarding@resend.dev until you verify a domain in Resend.
FOLLOW_EMAIL_FROM=Movers, Makers & Shakers <onboarding@resend.dev>
# Shared secret the Vercel cron job sends as Bearer token. Generate with: openssl rand -hex 32
CRON_SECRET=

# Admin allowlist — comma-separated emails that bypass certain UI gates.
ADMIN_EMAILS=

# Local action-layer DB pool — only used when running against local Supabase.
# For prod / staging set via the Supabase project's connection string instead.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
